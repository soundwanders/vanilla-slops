{
  "type": "module",
  "name": "vanilla-slops",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite --config vite.config.js",
    "dev:server": "nodemon src/server/index.js",
    "build": "npm run build:client",
    "build:client": "vite build --config vite.config.js",
    "start": "node src/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "db:verify": "node src/server/scripts/verify-database.js",
    "test:api": "curl http://localhost:8000/api/games?limit=3",
    "test:health": "curl http://localhost:8000/health",
    "prepare": "husky"
  },
  "keywords": [
    "javascript",
    "node",
    "express",
    "supabase",
    "steam",
    "launch",
    "options",
    "vanilla",
    "slops"
  ],
  "author": "soundwanders",
  "license": "MIT",
  "description": "Vanilla Slops",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "axios": "^1.7.9",
    "body-parser": "^1.20.3",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "supabase": "^2.6.8",
    "terser": "^5.44.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.10",
    "playwright": "^1.61.1",
    "serve": "^14.2.4",
    "sharp": "^0.35.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.6"
  },
  "lint-staged": {
    "src/**/*.js": "eslint"
  }
}
